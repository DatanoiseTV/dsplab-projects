// Soft clipper (tanh-based waveshaper)
// Usage: val y = soft_clip(x, drive);
//   drive - gain before clipping, 1.0 = unity
fun soft_clip(x: real, drive: real) : real {
  val v = x * drive;
  // tanh approximation: rational polynomial
  val v2 = v * v;
  return v * (27.0 + v2) / (27.0 + 9.0 * v2);
}
