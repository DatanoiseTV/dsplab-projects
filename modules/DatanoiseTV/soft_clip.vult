// Soft clipper using a tanh polynomial approximation
// Usage: val y = soft_clip(x, drive);
//   drive - pre-gain before clipping (1.0 = unity, higher = more saturation)
fun soft_clip(x:real, drive:real) : real {
  val v  = x * drive;
  val v2 = v * v;
  return v * (27.0 + v2) / (27.0 + 9.0 * v2);
}
