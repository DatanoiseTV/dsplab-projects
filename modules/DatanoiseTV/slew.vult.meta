{
  "schema_version": 1,
  "name": "Slew Limiter",
  "description": "Exponential slew limiter. Smooths abrupt value changes — use for portamento on pitch, parameter lag, or glide between control values.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "utility",
  "tags": ["utility", "slew", "portamento", "lag", "glide", "smooth"],
  "complexity": "beginner",
  "type": "module",
  "functions": [
    {
      "name": "slew",
      "signature": "slew(x:real, rate:real) : real",
      "description": "rate controls speed: 1.0 = instant track, ~0.001 = slow glide."
    }
  ]
}
