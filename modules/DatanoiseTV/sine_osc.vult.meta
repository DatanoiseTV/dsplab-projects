  "category": "oscillator",
  "tags": ["oscillator", "sine", "tone", "fundamental"],
  "complexity": "beginner",
  "type": "module",
  "functions": [
    {
      "name": "sine_osc",
      "signature": "sine_osc(freq:real) : real",
      "description": "Returns a sine wave at freq Hz, amplitude -1..1."
    }
  ]
}
