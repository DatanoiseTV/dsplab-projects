{
  "schema_version": 1,
  "name": "Sine Oscillator",
  "description": "Phase-accumulator sine oscillator. Uses Vult's built-in sin() which maps to a table in C/embedded targets for efficiency.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
