{
  "schema_version": 1,
  "name": "Equal-Power Crossfade",
  "description": "Crossfades two signals with constant perceived loudness using a quarter-circle equal-power law.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "utility",
  "tags": ["utility", "crossfade", "mix", "blend", "equal-power"],
  "complexity": "beginner",
  "type": "module",
  "functions": [
    {
      "name": "xfade",
      "signature": "xfade(a:real, b:real, pos:real) : real",
      "description": "pos=0.0 returns a, pos=1.0 returns b, midpoint is equal power."
    }
  ]
}
