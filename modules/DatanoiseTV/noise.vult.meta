{
  "schema_version": 1,
  "name": "Noise Generators",
  "description": "White and pink noise generators. The pink noise approximation uses Paul Kellet's method for accurate 1/f spectral shaping.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
