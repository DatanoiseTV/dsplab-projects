  "category": "modulator",
  "tags": ["noise", "white-noise", "pink-noise", "random", "generator", "percussion"],
  "complexity": "beginner",
  "type": "module",
  "functions": [
    {
      "name": "white_noise",
      "signature": "white_noise() : real",
      "description": "Returns white noise in the range -1..1 from a fast LCG."
    },
    {
      "name": "pink_noise",
      "signature": "pink_noise() : real",
      "description": "Returns 1/f pink noise, normalised to approximately -1..1."
    }
  ]
}
