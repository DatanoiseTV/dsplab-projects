{
  "schema_version": 1,
  "name": "Soft Clipper",
  "description": "Smooth saturation using a rational polynomial approximation to tanh. Adds even-order harmonics and hard-limits peaks without harshness.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "effect",
  "tags": ["saturation", "soft-clip", "tanh", "distortion", "waveshaper", "harmonic"],
  "complexity": "beginner",
  "type": "module",
  "functions": [
    {
      "name": "soft_clip",
      "signature": "soft_clip(x:real, drive:real) : real",
      "description": "Applies tanh-shaped saturation. drive=1.0 is unity; higher values increase saturation."
    }
  ]
}
