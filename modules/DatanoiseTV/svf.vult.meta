{
  "schema_version": 1,
  "name": "State Variable Filter",
  "description": "Simultaneous lowpass, bandpass, and highpass outputs from a single second-order topology. Clean resonance with no instability at high Q.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "filter",
  "tags": ["filter", "svf", "lowpass", "bandpass", "highpass", "resonant"],
  "complexity": "intermediate",
  "type": "module",
  "functions": [
    {
      "name": "svf_lp",
      "signature": "svf_lp(x:real, fc:real, q:real) : real",
      "description": "Lowpass output. fc is normalised 0..0.49; q >= 0.5."
    },
    {
      "name": "svf_bp",
      "signature": "svf_bp(x:real, fc:real, q:real) : real",
      "description": "Bandpass output."
    },
    {
      "name": "svf_hp",
      "signature": "svf_hp(x:real, fc:real, q:real) : real",
      "description": "Highpass output."
    }
  ]
}
