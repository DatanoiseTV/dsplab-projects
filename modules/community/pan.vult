// Equal-power stereo panner
// Usage: val l = pan_left(x, pos);  val r = pan_right(x, pos);
//   pos: -1.0 = full left, 0.0 = centre, 1.0 = full right
fun pan_left(x:real, pos:real) : real {
  val angle = (pos + 1.0) * 0.785398;
  return x * cos(angle);
}

fun pan_right(x:real, pos:real) : real {
  val angle = (pos + 1.0) * 0.785398;
  return x * sin(angle);
}
