{
  "schema_version": 1,
  "name": "RMS Compressor",
  "description": "RMS-detecting compressor with variable threshold, ratio, attack, and makeup gain. Smoothed gain reduction avoids pumping artefacts.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "modulator",
  "tags": ["effect", "compressor", "dynamics", "rms", "limiter", "mastering"],
  "complexity": "intermediate",
  "type": "preset",
  "inputs": { "audio": true, "midi": false, "cv": false },
  "knobs": {
    "30": { "name": "Threshold",   "description": "Compression threshold, 0.05 to 0.95", "default": 0.5, "unit": "norm" },
    "31": { "name": "Ratio",       "description": "Compression ratio, 1:1 to 20:1", "default": 0.2, "unit": "norm" },
    "32": { "name": "Attack",      "description": "Gain envelope attack time", "default": 0.3, "unit": "norm" },
    "33": { "name": "Makeup Gain", "description": "Post-compression gain boost, 1x to 5x", "default": 0.2, "unit": "norm" }
  }
}
