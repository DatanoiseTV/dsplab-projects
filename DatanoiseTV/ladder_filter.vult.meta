{
  "schema_version": 1,
  "name": "Moog Ladder Filter",
  "description": "4-pole lowpass ladder filter modelled after the classic Moog topology. Uses tanh saturation in each integrator stage for analog warmth. Self-oscillates at high resonance.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "filter",
  "tags": ["filter", "lowpass", "analog", "moog", "resonant", "saturation"],
  "complexity": "intermediate",
  "type": "preset",
  "inputs": { "audio": true, "midi": false, "cv": false },
  "knobs": {
    "30": { "name": "Cutoff",    "description": "Filter cutoff, exponentially scaled", "default": 0.5, "unit": "norm" },
    "31": { "name": "Resonance", "description": "Filter resonance — self-oscillates above 0.95", "default": 0.1, "unit": "norm" }
  }
}
