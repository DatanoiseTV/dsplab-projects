{
  "schema_version": 1,
  "name": "Three-Osc Synth",
  "description": "Three-oscillator subtractive synthesizer: a sawtooth, a PWM pulse with variable width and detune, and a sub-octave sine, all fed into a resonant SVF lowpass.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "synthesizer",
  "tags": ["synthesizer", "subtractive", "saw", "pulse", "pwm", "sub", "monophonic"],
  "complexity": "intermediate",
  "type": "preset",
  "inputs": { "audio": false, "midi": true, "cv": false },
  "knobs": {
    "30": { "name": "Osc2 Detune", "description": "Fine detune of oscillator 2 in semitones, -1 to +1", "default": 0.52, "unit": "semitone" },
    "31": { "name": "Pulse Width", "description": "PWM width of oscillator 2, 5% to 50%", "default": 0.5, "unit": "norm" },
    "32": { "name": "Sub Level",   "description": "Level of the sub-octave sine oscillator", "default": 0.4, "unit": "norm" },
    "33": { "name": "Filter Cutoff","description": "SVF lowpass cutoff, exponential scaling", "default": 0.45, "unit": "norm" }
  }
}
