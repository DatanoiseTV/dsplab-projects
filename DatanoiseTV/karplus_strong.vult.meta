{
  "schema_version": 1,
  "name": "Karplus-Strong String",
  "description": "Physical model of a plucked string using the Karplus-Strong algorithm. A noise burst is fed into a delay loop with a one-pole lowpass feedback, producing realistic string and harp-like tones.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "synthesizer",
  "tags": ["synthesizer", "physical-model", "karplus-strong", "string", "plucked", "acoustic"],
  "complexity": "intermediate",
  "type": "preset",
  "inputs": { "audio": false, "midi": true, "cv": false },
  "knobs": {
    "30": { "name": "Damping",      "description": "String brightness — higher = brighter, longer decay", "default": 0.96, "unit": "norm" },
    "31": { "name": "Output Level", "description": "Output amplitude", "default": 0.8, "unit": "norm" }
  }
}
