{
  "schema_version": 1,
  "name": "Subtractive Synth",
  "description": "Classic subtractive synthesizer: sawtooth oscillator through a resonant SVF lowpass with a full ADSR-style envelope controlling both amplitude and implied brightness.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "synthesizer",
  "tags": ["synthesizer", "subtractive", "saw", "filter", "svf", "monophonic"],
  "complexity": "intermediate",
  "type": "preset",
  "inputs": { "audio": false, "midi": true, "cv": false },
  "knobs": {
    "30": { "name": "Filter Cutoff",    "description": "SVF lowpass cutoff, exponential scaling", "default": 0.4,  "unit": "norm" },
    "31": { "name": "Filter Resonance", "description": "SVF resonance / Q", "default": 0.1,  "unit": "norm" },
    "32": { "name": "Attack",           "description": "Amplitude envelope attack time, 0-2s", "default": 0.05, "unit": "seconds" },
    "33": { "name": "Release",          "description": "Amplitude envelope release time, 0-4s", "default": 0.3,  "unit": "seconds" }
  }
}
