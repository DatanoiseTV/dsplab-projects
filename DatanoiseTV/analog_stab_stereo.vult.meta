{
  "schema_version": 1,
  "name": "Analog Stab Stereo",
  "description": "Powerful analog-style stab with dual detuned oscillators, punchy ladder filter, and built-in stereo chorus for wide spatial imaging.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-10",
  "license": "MIT",
  "category": "synthesizer",
  "tags": [
    "synthesizer",
    "analog",
    "stab",
    "stereo",
    "chorus"
  ],
  "complexity": "intermediate",
  "type": "preset",
  "role": "instrument",
  "inputs": {
    "audio": false,
    "midi": true,
    "cv": false
  },
  "knobs": {
    "30": {
      "name": "Cutoff",
      "description": "Filter base cutoff frequency",
      "default": 0.2,
      "unit": "normalized"
    },
    "31": {
      "name": "Resonance",
      "description": "Filter resonance amount",
      "default": 0.4,
      "unit": "normalized"
    },
    "32": {
      "name": "Decay",
      "description": "Envelope decay time",
      "default": 0.3,
      "unit": "normalized"
    },
    "33": {
      "name": "FX Mix",
      "description": "Stereo chorus widening amount",
      "default": 0.4,
      "unit": "normalized"
    }
  }
}
