{
  "schema_version": 1,
  "name": "Wavefolder",
  "description": "Analog-style wavefolder using a triangle-fold function. Adds upper harmonics by folding the waveform back on itself, inspired by West Coast synthesis techniques.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "modulator",
  "tags": ["effect", "wavefolder", "distortion", "harmonic", "west-coast", "buchla"],
  "complexity": "beginner",
  "type": "preset",
  "inputs": { "audio": true, "midi": false, "cv": false },
  "knobs": {
    "30": { "name": "Fold Amount", "description": "Number of folds applied — 0 = none, 1 = maximum", "default": 0.3, "unit": "norm" },
    "31": { "name": "Input Gain",  "description": "Pre-fold drive", "default": 0.2, "unit": "norm" },
    "32": { "name": "Mix",         "description": "Dry/wet mix", "default": 0.8, "unit": "norm" }
  }
}
