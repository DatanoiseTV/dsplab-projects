{
  "schema_version": 1,
  "name": "Stereo Chorus",
  "description": "Dual-voice chorus with two LFOs running 180\u00b0 out of phase. Summed to mono in DSPLab but produces wide movement and shimmer.",
  "author": "DatanoiseTV",
  "version": "1.0.0",
  "created_at": "2026-03-09",
  "license": "MIT",
  "category": "effect",
  "tags": [
    "effect",
    "chorus",
    "modulation",
    "stereo",
    "lfo",
    "width"
  ],
  "complexity": "intermediate",
  "type": "preset",
  "role": "effect",
  "inputs": {
    "audio": true,
    "midi": false,
    "cv": false
  },
  "knobs": {
    "30": {
      "name": "Rate",
      "description": "LFO modulation rate in Hz, 0.1 to 4 Hz",
      "default": 0.15,
      "unit": "hz"
    },
    "31": {
      "name": "Depth",
      "description": "Modulation depth \u2014 wider = more detuning",
      "default": 0.3,
      "unit": "norm"
    },
    "32": {
      "name": "Mix",
      "description": "Dry/wet mix",
      "default": 0.5,
      "unit": "norm"
    }
  }
}
